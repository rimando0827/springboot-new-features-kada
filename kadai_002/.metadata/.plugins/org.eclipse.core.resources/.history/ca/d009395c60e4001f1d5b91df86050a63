package com.example.samuraitravel.form;


import java.util.List;

import jakarta.validation.constraints.NotBlank;
import lombok.Data;

@Data
public class ReviewForm {
	@NotBlank(message ="五段階で選択してください")
	private Integer reviewStar;
	
	@NotBlank(message ="レビュー内容を入力してください")
	private String thoughts;
	
	//ドロップダウンリスト
	private String selectedValue;
	private List<String>reviewStars ;
	
	public String getSelectedReviewStars() {
		return selectedValue;
	}
	
	public void getSelectedReviewStars(String selectedValue) {
		this.selectedValue=selectedValue;
	}
	
	public List<String> getReviewStar() {
		return reviewStars;
	}
	
	public void setReviewStars(List<String>reviewStars ) {
		this.reviewStars = reviewStars; 
	}
}
